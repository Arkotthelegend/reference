[
  {"type": "math_show", "q": "Draw the graph of y = \\log_2(x-2)+2.", "c": "\\text{Domain: } \\{x : x > 2\\}<br><br>\\text{Range: } \\mathbb{R}<br><br>\\text{Asymptote: } x = 2<br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 240.5 350 L 241 280 L 242 230 L 245 200 L 250 180 L 260 160 L 280 140 L 320 120 L 360 100' fill='none' stroke='#00EEFF' stroke-width='4'/><line x1='240' y1='0' x2='240' y2='400' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='245' y='215' fill='white' font-size='12'>(9/4,0)</text><text x='255' y='185' fill='white' font-size='12'>(5/2,1)</text><text x='265' y='165' fill='white' font-size='12'>(3,2)</text><text x='285' y='145' fill='white' font-size='12'>(4,3)</text><text x='325' y='125' fill='white' font-size='12'>(6,4)</text><text x='245' y='380' fill='#ff0055' font-size='12'>x=2</text></svg></div>"},
  {"type": "math_show", "q": "Sketch the graph of y = \\log_2(x-3) and determine the domain and range of given function.", "c": "\\text{Domain: } \\{x : x > 3\\}<br><br>\\text{Range: } \\mathbb{R}<br><br>\\text{Asymptote: } x = 3<br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 261 350 L 262 280 L 265 240 L 270 220 L 280 200 L 300 180 L 340 160 L 380 148' fill='none' stroke='#00EEFF' stroke-width='4'/><line x1='260' y1='0' x2='260' y2='400' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='270' y='245' fill='white' font-size='12'>(13/4,-2)</text><text x='275' y='225' fill='white' font-size='12'>(7/2,-1)</text><text x='285' y='205' fill='white' font-size='12'>(4,0)</text><text x='305' y='185' fill='white' font-size='12'>(5,1)</text><text x='345' y='165' fill='white' font-size='12'>(7,2)</text></svg></div>"},
  {"type": "math_show", "q": "Draw the graph of y = \\log_{\\frac{1}{2}} (x+2)+1. Lable any points of intersection with coordinate axes. Write down the equation of the asymptote.", "c": "\\text{Domain: } \\{x : x > -2\\}<br><br>\\text{Range: } \\mathbb{R}<br><br>\\text{Asymptote: } x = -2<br><br>x = 0 \\Rightarrow y = \\log_{\\frac{1}{2}}(2)+1 = -1+1 = 0 \\Rightarrow (0,0)<br><br>y = 0 \\Rightarrow \\log_{\\frac{1}{2}}(x+2)+1 = 0 \\Rightarrow x+2 = 2 \\Rightarrow x = 0 \\Rightarrow (0,0)<br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 161 50 L 165 140 L 170 160 L 180 180 L 200 200 L 240 220 L 320 240' fill='none' stroke='#00EEFF' stroke-width='4'/><line x1='160' y1='0' x2='160' y2='400' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='165' y='135' fill='white' font-size='12'>(-7/4,3)</text><text x='175' y='155' fill='white' font-size='12'>(-3/2,2)</text><text x='185' y='175' fill='white' font-size='12'>(-1,1)</text><text x='205' y='195' fill='white' font-size='12'>(0,0)</text><text x='245' y='225' fill='white' font-size='12'>(2,-1)</text></svg></div>"},
  {"type": "math_show", "q": "Draw the graph of y = 3\\log_2 x.", "c": "\\text{Domain: } \\{x : x > 0\\}<br><br>\\text{Range: } \\mathbb{R}<br><br>\\text{Asymptote: } x = 0<br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 201 380 L 205 320 L 210 260 L 220 200 L 240 140 L 280 80 L 360 20' fill='none' stroke='#00EEFF' stroke-width='4'/><line x1='200' y1='0' x2='200' y2='400' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='210' y='325' fill='white' font-size='12'>(1/4,-6)</text><text x='215' y='265' fill='white' font-size='12'>(1/2,-3)</text><text x='225' y='205' fill='white' font-size='12'>(1,0)</text><text x='245' y='145' fill='white' font-size='12'>(2,3)</text><text x='285' y='85' fill='white' font-size='12'>(4,6)</text></svg></div>"},
  {"type": "math_show", "q": "Sketch the graph of function y = 2^{x+1}-3. Then determine the domain and range of given function.", "c": "\\text{Domain: } \\mathbb{R}<br><br>\\text{Range: } \\{y : y > -3\\}<br><br>\\text{Asymptote: } y = -3<br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 40 258 L 140 255 L 160 250 L 180 240 L 200 220 L 220 180 L 240 100 L 250 20' fill='none' stroke='#00EEFF' stroke-width='4'/><line x1='0' y1='260' x2='400' y2='260' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='140' y='270' fill='white' font-size='12'>(-2,-2.5)</text><text x='185' y='255' fill='white' font-size='12'>(-1,-2)</text><text x='205' y='225' fill='white' font-size='12'>(0,-1)</text><text x='225' y='185' fill='white' font-size='12'>(1,1)</text><text x='245' y='105' fill='white' font-size='12'>(2,5)</text></svg></div>"},
  {"type": "math_show", "q": "Find the domain and range of the function f(x) = 2\\log(2x-4)+5.", "c": "2x - 4 > 0<br><br>2x > 4<br><br>x > 2<br><br><strong>\\text{Domain: } \\{x : x > 2\\}</strong><br><br><strong>\\text{Range: } \\mathbb{R}</strong>"},
  {"type": "math_show", "q": "Draw the graph y = -2^x.", "c": "\\text{Domain: } \\mathbb{R}<br><br>\\text{Range: } \\{y : y < 0\\}<br><br>\\text{Asymptote: } y = 0<br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 40 201 L 160 205 L 180 210 L 200 220 L 220 240 L 240 280 L 260 360 L 270 400' fill='none' stroke='#00EEFF' stroke-width='4'/><line x1='0' y1='200' x2='400' y2='200' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='150' y='195' fill='white' font-size='12'>(-2,-1/4)</text><text x='170' y='225' fill='white' font-size='12'>(-1,-1/2)</text><text x='205' y='235' fill='white' font-size='12'>(0,-1)</text><text x='225' y='255' fill='white' font-size='12'>(1,-2)</text><text x='245' y='295' fill='white' font-size='12'>(2,-4)</text></svg></div>"},
  {"type": "math_show", "q": "From the graph of y = \\log_2 x, draw step by step transformation graph to get the graph of y = \\log_2(x-1)+2.", "c": "y = \\log_2 x<br><br>\\xrightarrow{\\text{horizontal translation 1 unit}} y = \\log_2(x-1)<br><br>\\xrightarrow{\\text{vertical translation 2 units}} y = \\log_2(x-1)+2<br><br><strong>\\text{Asymptote: } x = 1</strong><br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 221 350 L 225 220 L 230 180 L 240 160 L 260 140 L 300 120 L 380 95' fill='none' stroke='#00EEFF' stroke-width='4'/><path d='M 201 350 L 205 220 L 210 200 L 220 180 L 240 160 L 280 140 L 360 120' fill='none' stroke='#888888' stroke-width='2'/><line x1='220' y1='0' x2='220' y2='400' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='235' y='185' fill='white' font-size='12'>(3/2,1)</text><text x='245' y='155' fill='white' font-size='12'>(2,2)</text><text x='265' y='135' fill='white' font-size='12'>(3,3)</text><text x='305' y='115' fill='white' font-size='12'>(5,4)</text><text x='215' y='205' fill='#888888' font-size='12'>(1/2,-1)</text><text x='225' y='185' fill='#888888' font-size='12'>(1,0)</text><text x='245' y='165' fill='#888888' font-size='12'>(2,1)</text><text x='285' y='145' fill='#888888' font-size='12'>(4,2)</text></svg></div>"},
  {"type": "math_show", "q": "The point (0,1) is on the graph of y = 3^x. Find the corresponding point on the graph of each of the following functions: y = -2 \\cdot 3^x, y = -2 \\cdot 3^{x-2} + 1 and y = -2 \\cdot 3^{-2x-2} + 1.", "c": "\\text{For } y = -2 \\cdot 3^x: (0, 1) \\rightarrow (0, -2(1)) = (0, -2)<br><br>\\text{For } y = -2 \\cdot 3^{x-2} + 1: x-2 = 0 \\Rightarrow x = 2, y = -2(1) + 1 = -1 \\Rightarrow (2, -1)<br><br>\\text{For } y = -2 \\cdot 3^{-2x-2} + 1: -2x-2 = 0 \\Rightarrow x = -1, y = -2(1) + 1 = -1 \\Rightarrow (-1, -1)<br><br><strong>(0,-2), (2,-1), (-1,-1)</strong>"},
  {"type": "math_show", "q": "Sketch the graph of function y = 2^x + 3 and determine the domain and range of given function.", "c": "\\text{Domain: } \\mathbb{R}<br><br>\\text{Range: } \\{y : y > 3\\}<br><br>\\text{Asymptote: } y = 3<br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 40 139 L 160 135 L 180 130 L 200 120 L 220 100 L 240 60 L 255 0' fill='none' stroke='#00EEFF' stroke-width='4'/><line x1='0' y1='140' x2='400' y2='140' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='155' y='150' fill='white' font-size='12'>(-2,13/4)</text><text x='175' y='145' fill='white' font-size='12'>(-1,7/2)</text><text x='205' y='125' fill='white' font-size='12'>(0,4)</text><text x='225' y='105' fill='white' font-size='12'>(1,5)</text><text x='245' y='65' fill='white' font-size='12'>(2,7)</text></svg></div>"},
  {"type": "math_show", "q": "Draw the graph y = 2^{x-1} + 2. Determine the domain, range and asymptote.", "c": "\\text{Domain: } \\mathbb{R}<br><br>\\text{Range: } \\{y : y > 2\\}<br><br>\\text{Asymptote: } y = 2<br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 40 159 L 180 155 L 200 150 L 220 140 L 240 120 L 260 80 L 280 0' fill='none' stroke='#00EEFF' stroke-width='4'/><line x1='0' y1='160' x2='400' y2='160' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='170' y='170' fill='white' font-size='12'>(-1,9/4)</text><text x='195' y='165' fill='white' font-size='12'>(0,5/2)</text><text x='225' y='145' fill='white' font-size='12'>(1,3)</text><text x='245' y='125' fill='white' font-size='12'>(2,4)</text><text x='265' y='85' fill='white' font-size='12'>(3,6)</text></svg></div>"},
  {"type": "math_show", "q": "Draw the graph of y = 2^{x-1} + 1. Write down the equation of the asymptote of the graph.", "c": "\\text{Domain: } \\mathbb{R}<br><br>\\text{Range: } \\{y : y > 1\\}<br><br><strong>\\text{Asymptote: } y = 1</strong><br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 40 179 L 160 177 L 180 175 L 200 170 L 220 160 L 240 140 L 280 60' fill='none' stroke='#00EEFF' stroke-width='4'/><line x1='0' y1='180' x2='400' y2='180' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='150' y='190' fill='white' font-size='12'>(-2,9/8)</text><text x='170' y='190' fill='white' font-size='12'>(-1,5/4)</text><text x='205' y='175' fill='white' font-size='12'>(0,3/2)</text><text x='225' y='165' fill='white' font-size='12'>(1,2)</text><text x='245' y='145' fill='white' font-size='12'>(2,3)</text></svg></div>"},
  {"type": "math_show", "q": "Draw the graph y = 2^{-x} - 3, and determine the domain and range.", "c": "\\text{Domain: } \\mathbb{R}<br><br>\\text{Range: } \\{y : y > -3\\}<br><br>\\text{Asymptote: } y = -3<br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 120 0 L 160 180 L 180 220 L 200 240 L 220 250 L 240 255 L 400 259' fill='none' stroke='#00EEFF' stroke-width='4'/><line x1='0' y1='260' x2='400' y2='260' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='165' y='185' fill='white' font-size='12'>(-2,1)</text><text x='185' y='225' fill='white' font-size='12'>(-1,-1)</text><text x='205' y='245' fill='white' font-size='12'>(0,-2)</text><text x='225' y='265' fill='white' font-size='12'>(1,-5/2)</text><text x='245' y='270' fill='white' font-size='12'>(2,-11/4)</text></svg></div>"},
  {"type": "math_show", "q": "Determine the domain and range of the function y = e^{x-2} + 3. Write down the equation of asymptote of the given function.", "c": "<strong>\\text{Domain: } \\mathbb{R}</strong><br><br><strong>\\text{Range: } \\{y : y > 3\\}</strong><br><br><strong>\\text{Asymptote: } y = 3</strong>"},
  {"type": "math_show", "q": "Draw the graph of y = \\log_{\\frac{1}{2}}(x+1)-1.", "c": "\\text{Domain: } \\{x : x > -1\\}<br><br>\\text{Range: } \\mathbb{R}<br><br>\\text{Asymptote: } x = -1<br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 181 0 L 185 140 L 190 200 L 200 220 L 220 240 L 260 260 L 380 280' fill='none' stroke='#00EEFF' stroke-width='4'/><line x1='180' y1='0' x2='180' y2='400' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='195' y='195' fill='white' font-size='12'>(-1/2,0)</text><text x='205' y='225' fill='white' font-size='12'>(0,-1)</text><text x='225' y='245' fill='white' font-size='12'>(1,-2)</text><text x='265' y='265' fill='white' font-size='12'>(3,-3)</text></svg></div>"},
  {"type": "math_show", "q": "From the graph of y = \\log_{\\frac{1}{2}} x, draw step by step transformation graph to get the graph of y = \\log_{\\frac{1}{2}}(x-1)+3. Find the equation of the asymptote.", "c": "y = \\log_{\\frac{1}{2}} x<br><br>\\xrightarrow{\\text{horizontal translation 1 unit}} y = \\log_{\\frac{1}{2}}(x-1)<br><br>\\xrightarrow{\\text{vertical translation 3 units}} y = \\log_{\\frac{1}{2}}(x-1)+3<br><br><strong>\\text{Asymptote: } x = 1</strong><br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 221 0 L 225 60 L 230 120 L 240 140 L 260 160 L 300 180 L 380 200' fill='none' stroke='#00EEFF' stroke-width='4'/><path d='M 201 0 L 205 160 L 210 200 L 220 220 L 240 240 L 280 260 L 360 280' fill='none' stroke='#888888' stroke-width='2'/><line x1='220' y1='0' x2='220' y2='400' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='235' y='115' fill='white' font-size='12'>(3/2,4)</text><text x='245' y='135' fill='white' font-size='12'>(2,3)</text><text x='265' y='155' fill='white' font-size='12'>(3,2)</text><text x='305' y='175' fill='white' font-size='12'>(5,1)</text><text x='215' y='195' fill='#888888' font-size='12'>(1/2,1)</text><text x='225' y='225' fill='#888888' font-size='12'>(1,0)</text><text x='245' y='245' fill='#888888' font-size='12'>(2,-1)</text><text x='285' y='265' fill='#888888' font-size='12'>(4,-2)</text></svg></div>"},
  {"type": "math_show", "q": "Find the y-intercept, asymptote and the range of y = 8e^{x-1} + 5.", "c": "x = 0 \\Rightarrow y = 8e^{-1} + 5 = \\frac{8}{e} + 5<br><br><strong>\\text{y-intercept: } \\left(0, \\frac{8}{e} + 5\\right)</strong><br><br><strong>\\text{Asymptote: } y = 5</strong><br><br><strong>\\text{Range: } \\{y : y > 5\\}</strong>"},
  {"type": "math_show", "q": "Find \\frac{dy}{dx} if y = (x+1)^x.", "c": "y = (x+1)^x<br><br>\\ln y = x \\ln(x+1)<br><br>\\frac{1}{y} \\frac{dy}{dx} = \\ln(x+1) + \\frac{x}{x+1}<br><br><strong>\\frac{dy}{dx} = (x+1)^x \\left( \\frac{x}{x+1} + \\ln(x+1) \\right)</strong>"},
  {"type": "math_show", "q": "If y^2 e^x + \\ln(xy) = 1, find \\frac{dy}{dx}.", "c": "y^2 e^x + \\ln x + \\ln y = 1<br><br>2y \\frac{dy}{dx} e^x + y^2 e^x + \\frac{1}{x} + \\frac{1}{y} \\frac{dy}{dx} = 0<br><br>\\frac{dy}{dx} \\left( 2y e^x + \\frac{1}{y} \\right) = -y^2 e^x - \\frac{1}{x}<br><br><strong>\\frac{dy}{dx} = \\frac{-y^2 e^x - \\frac{1}{x}}{2y e^x + \\frac{1}{y}}</strong>"},
  {"type": "math_show", "q": "Differentiate the function xe^y + \\ln(xy) = \\sin x with respect to x.", "c": "x e^y + \\ln x + \\ln y = \\sin x<br><br>e^y + x e^y \\frac{dy}{dx} + \\frac{1}{x} + \\frac{1}{y} \\frac{dy}{dx} = \\cos x<br><br>\\frac{dy}{dx} \\left( x e^y + \\frac{1}{y} \\right) = \\cos x - e^y - \\frac{1}{x}<br><br><strong>\\frac{dy}{dx} = \\frac{\\cos x - e^y - \\frac{1}{x}}{x e^y + \\frac{1}{y}}</strong>"},
  {"type": "math_show", "q": "Differentiate y = x^{3x}, x > 0.", "c": "y = x^{3x}<br><br>\\ln y = 3x \\ln x<br><br>\\frac{1}{y} \\frac{dy}{dx} = 3 \\ln x + 3x \\left(\\frac{1}{x}\\right)<br><br>\\frac{1}{y} \\frac{dy}{dx} = 3 \\ln x + 3<br><br><strong>\\frac{dy}{dx} = x^{3x} (3 + 3 \\ln x)</strong>"},
  {"type": "math_show", "q": "Use logarithmic differentiation to find the derivative of y = x^{\\cos 2x} with respect to x.", "c": "y = x^{\\cos 2x}<br><br>\\ln y = \\cos 2x \\ln x<br><br>\\frac{1}{y} \\frac{dy}{dx} = -2 \\sin 2x \\ln x + \\cos 2x \\left(\\frac{1}{x}\\right)<br><br><strong>\\frac{dy}{dx} = x^{\\cos 2x} \\left( \\frac{\\cos 2x}{x} - 2 \\sin 2x \\ln x \\right)</strong>"},
  {"type": "math_show", "q": "Find \\frac{dy}{dx} if y^x = x^y.", "c": "y^x = x^y<br><br>x \\ln y = y \\ln x<br><br>\\ln y + \\frac{x}{y} \\frac{dy}{dx} = \\frac{dy}{dx} \\ln x + \\frac{y}{x}<br><br>\\frac{dy}{dx} \\left( \\frac{x}{y} - \\ln x \\right) = \\frac{y}{x} - \\ln y<br><br>\\frac{dy}{dx} \\left( \\frac{x - y \\ln x}{y} \\right) = \\frac{y - x \\ln y}{x}<br><br><strong>\\frac{dy}{dx} = \\frac{y^2 - xy \\ln y}{x^2 - xy \\ln x}</strong>"},
  {"type": "math_show", "q": "If x \\ln y + e^{xy} = 3^x y^3, find \\frac{dy}{dx}.", "c": "\\ln y + \\frac{x}{y} \\frac{dy}{dx} + e^{xy} \\left( y + x \\frac{dy}{dx} \\right) = 3^x \\ln 3 \\cdot y^3 + 3^x \\cdot 3y^2 \\frac{dy}{dx}<br><br>\\frac{dy}{dx} \\left( \\frac{x}{y} + x e^{xy} - 3^{x+1} y^2 \\right) = y^3 3^x \\ln 3 - \\ln y - y e^{xy}<br><br><strong>\\frac{dy}{dx} = \\frac{y^3 \\cdot 3^x \\ln 3 - \\ln y - y e^{xy}}{\\frac{x}{y} + x e^{xy} - 3^{x+1} y^2}</strong>"},
  {"type": "math_show", "q": "Differentiate y = x^{2x}, x > 0.", "c": "y = x^{2x}<br><br>\\ln y = 2x \\ln x<br><br>\\frac{1}{y} \\frac{dy}{dx} = 2 \\ln x + 2x \\left(\\frac{1}{x}\\right)<br><br>\\frac{1}{y} \\frac{dy}{dx} = 2 \\ln x + 2<br><br><strong>\\frac{dy}{dx} = x^{2x} (2 + 2 \\ln x)</strong>"},
  {"type": "math_show", "q": "Draw the graph of y = -2 \\cdot 3^{x+1} + 2. Write down the equation of the asymptote.", "c": "\\text{Domain: } \\mathbb{R}<br><br>\\text{Range: } \\{y : y < 2\\}<br><br><strong>\\text{Asymptote: } y = 2</strong><br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 40 161 L 160 173 L 180 200 L 200 280 L 210 400' fill='none' stroke='#00EEFF' stroke-width='4'/><line x1='0' y1='160' x2='400' y2='160' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='145' y='185' fill='white' font-size='12'>(-2,4/3)</text><text x='185' y='195' fill='white' font-size='12'>(-1,0)</text><text x='205' y='285' fill='white' font-size='12'>(0,-4)</text></svg></div>"},
  {"type": "math_show", "q": "Draw the graph of y = \\log_2(x+2)-1. Write down the equation of the asymptote.", "c": "\\text{Domain: } \\{x : x > -2\\}<br><br>\\text{Range: } \\mathbb{R}<br><br><strong>\\text{Asymptote: } x = -2</strong><br><br><div style='width: 300px; height: 300px; margin: 20px auto; border: 1px solid #444; padding: 10px; background: #1e1e1e; border-radius: 8px;'><svg viewBox='0 0 400 400' width='100%' height='100%' xmlns='http://www.w3.org/2000/svg'><line x1='0' y1='200' x2='400' y2='200' stroke='#FFFFFF' stroke-width='2'/><line x1='200' y1='0' x2='200' y2='400' stroke='#FFFFFF' stroke-width='2'/><path d='M 161 380 L 165 300 L 170 240 L 180 220 L 200 200 L 240 180 L 320 160' fill='none' stroke='#00EEFF' stroke-width='4'/><line x1='160' y1='0' x2='160' y2='400' stroke='#ff0055' stroke-dasharray='5,5' stroke-width='2'/><text x='175' y='245' fill='white' font-size='12'>(-3/2,-2)</text><text x='185' y='225' fill='white' font-size='12'>(-1,-1)</text><text x='205' y='195' fill='white' font-size='12'>(0,0)</text><text x='245' y='175' fill='white' font-size='12'>(2,1)</text></svg></div>"}
